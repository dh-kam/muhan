# =============================================================================
#  Muhan MUD Docker 설정
#  이 파일을 .env로 복사하여 환경에 맞게 수정하세요.
#  cp .env.example .env
# =============================================================================

# ─── 게임 서버 설정 ─────────────────────────────────────────
# 게임 데이터 루트 디렉토리 (player/, rooms/, objmon/ 등이 있는 경로)
MUHAN_DATA_DIR=.

# 컨테이너 사용자 UID/GID (호스트와 일치시켜야 볼륨 권한 문제 방지)
# 현재 호스트의 UID/GID 확인: id -u && id -g
MUHAN_UID=1000
MUHAN_GID=1000

# TCP 게임 서버 포트 (telnet 접속)
MUHAN_TCP_PORT=4000

# WebSocket 프록시 포트
MUHAN_WS_PORT=4041

# Web UI 포트 (Nginx)
MUHAN_WEBUI_PORT=8080

# 타임존
TZ=Asia/Seoul

# ─── PostgreSQL 설정 (선택적, DB Import용) ─────────────────
MUHAN_POSTGRES_DB=muhan
MUHAN_POSTGRES_USER=muhan
MUHAN_POSTGRES_PASSWORD=muhan_dev_password
MUHAN_POSTGRES_PORT=55432
MUHAN_POSTGRES_SCHEMA=muhan_import

# Optional import defaults consumed by scripts/db-smoke-postgres.sh.
MUHAN_IMPORT_RUN_ID=docker-smoke
MUHAN_SOURCE_ROOT_LABEL=docker-postgres
